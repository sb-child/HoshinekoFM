{
  "name": "material-3-file-manager",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/build-native.cjs && tsc -p electron/tsconfig.json && node scripts/copy-native.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:5173 && node scripts/build-native.cjs && tsc -p electron/tsconfig.json && node scripts/set-cjs.cjs && node scripts/copy-native.cjs && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && node scripts/set-cjs.cjs && electron-builder"
  },
  "dependencies": {
    "@fontsource-variable/material-symbols-rounded": "^5.2.45",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/roboto": "^5.2.10",
    "@lit-labs/react": "^2.1.3",
    "@lit/react": "^1.0.8",
    "@material/web": "^2.4.1",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "dbus-next": "^0.10.2",
    "node-pty": "1.2.0-beta.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-toastify": "^11.1.0",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.6",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^7.3.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.material3.filemanager",
    "productName": "Materials",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/**/*"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "icon": "assets/icon.png"
    }
  }
}
